# MongoDB Atlas connection string (a single database is used for everything).
MONGODB_URI=

# Google OAuth client, from the Google Cloud Console (OAuth consent screen +
# Web application credentials). Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google   (dev)
#   https://<your-domain>/api/auth/callback/google   (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth session encryption secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# The app's own base URL — used by NextAuth for callbacks/redirects.
NEXTAUTH_URL=http://localhost:3000

# Groq API key for the Marshal (AI Q&A over your attendance + grades).
# Get one at https://console.groq.com/keys
GROQ_API_KEY=
# Llama 3.1 70B on Groq. Override if your account serves a different id —
# Groq replaced llama-3.1-70b-versatile with llama-3.3-70b-versatile.
GROQ_MODEL=llama-3.1-70b-versatile
